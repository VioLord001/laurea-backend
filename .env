# ============================================
# LAUREA FASHION HOUSE — BACKEND ENVIRONMENT
# ============================================

# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# Database (PostgreSQL)
# Get from: supabase.com or railway.app
DATABASE_URL=postgresql://username:password@localhost:5432/laurea_db

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# Stripe Payments
# Get from: dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Cloudinary (Image Storage)
# Get from: cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (Resend)
# Get from: resend.com
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=noreply@laureafashionhouse.com

# Admin
ADMIN_EMAIL=admin@laureafashionhouse.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
